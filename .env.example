# Harbor Environment Variables

# Server port (default: 3000)
PORT=3000

# JWT secret — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# AES-256 encryption key for LLAT tokens stored in DB — must be exactly 32 characters
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# Directory where SQLite database is stored
DATA_DIR=./data
